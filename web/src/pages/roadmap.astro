---
import AppLayout from "../layouts/AppLayout.astro";
import { ROADMAP_SOURCE_PATH, getRoadmapMarkdown } from "../lib/content";
import { renderMarkdown } from "../lib/markdown";

const html = renderMarkdown(getRoadmapMarkdown(), ROADMAP_SOURCE_PATH);
---

<AppLayout title="Roadmap" description="Master 16-week GenAI engineer preparation roadmap.">
	<section class="section-block">
		<div class="doc-panel doc-heading">
			<span class="kicker">Roadmap</span>
			<h1>16-Week GenAI Engineer Path</h1>
			<p>
				Use this as your master navigation layer, then dive into each competency module for explainers and
				interview drills.
			</p>
		</div>
	</section>

	<section class="section-block">
		<article class="doc-panel markdown" set:html={html} />
	</section>
</AppLayout>
