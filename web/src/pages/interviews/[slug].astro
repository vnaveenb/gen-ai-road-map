---
import AppLayout from "../../layouts/AppLayout.astro";
import { getDocBySlug, getDocsByType, getRelatedDocs, routeForDoc } from "../../lib/content";
import { renderMarkdown } from "../../lib/markdown";

export function getStaticPaths() {
	return getDocsByType("interview").map((doc) => ({
		params: { slug: doc.slug }
	}));
}

const { slug } = Astro.params;
const doc = getDocBySlug("interview", slug ?? "");

if (!doc) {
	return Astro.redirect("/roadmap");
}

const tocEntries = doc.headings.filter((heading) => heading.level === 2 || heading.level === 3);
const questionEntries = doc.headings.filter((heading) => heading.level === 3 && /^Q\d+/i.test(heading.text));
const relatedDocs = getRelatedDocs(doc);
const html = renderMarkdown(doc.content, doc.sourcePath);
---

<AppLayout title={doc.title} description={doc.excerpt || doc.title}>
	<section class="section-block">
		<div class="doc-panel doc-heading">
			<span class="kicker">{doc.competency} · Interview Pack</span>
			<h1>{doc.title}</h1>
			<p>{doc.excerpt || "Practice deep technical questions with layered answers."}</p>
			<div class="meta-row">
				<span class="pill pill-accent">{doc.difficulty}</span>
				{doc.questionCount ? <span class="pill">{doc.questionCount} questions</span> : null}
				<span class="pill">v{doc.version}</span>
			</div>
			<div class="reader-actions" data-reader-actions data-doc-key={`interview:${doc.slug}`}>
				<button class="reader-btn" type="button" data-toggle-read aria-pressed="false">Mark read</button>
				<button class="reader-btn" type="button" data-toggle-bookmark aria-pressed="false">Bookmark</button>
				<span class="reader-hint" data-reader-status>Not tracked yet</span>
			</div>
		</div>
	</section>

	<section class="section-block doc-wrapper">
		<aside class="doc-panel toc-panel">
			<h3>Interview Sections</h3>
			<ul class="toc-list">
				{tocEntries.map((heading) => (
					<li class={heading.level === 3 ? "toc-level-3" : ""}>
						<a href={`#${heading.slug}`}>{heading.text}</a>
					</li>
				))}
			</ul>
			{questionEntries.length ? (
				<div class="question-jump" aria-label="Question quick jump">
					<h3>Question Jump</h3>
					<ul class="question-jump-list">
						{questionEntries.map((heading) => (
							<li>
								<a href={`#${heading.slug}`}>{heading.text}</a>
							</li>
						))}
					</ul>
				</div>
			) : null}
		</aside>

		<article class="doc-panel" data-doc-type="interview">
			<details class="toc-mobile">
				<summary>Jump to section</summary>
				<ul class="toc-list">
					{tocEntries.map((heading) => (
						<li class={heading.level === 3 ? "toc-level-3" : ""}>
							<a href={`#${heading.slug}`}>{heading.text}</a>
						</li>
					))}
				</ul>
			</details>
			{questionEntries.length ? (
				<details class="toc-mobile question-jump-mobile">
					<summary>Jump to question</summary>
					<ul class="question-jump-list">
						{questionEntries.map((heading) => (
							<li>
								<a href={`#${heading.slug}`}>{heading.text}</a>
							</li>
						))}
					</ul>
				</details>
			) : null}
			<div class="markdown" set:html={html} />
		</article>
	</section>

	{relatedDocs.length ? (
		<section class="section-block">
			<div class="section-head">
				<h2>Related Explainers</h2>
				<p>Use these explainers to reinforce weak interview topics.</p>
			</div>
			<div class="related-list">
				{relatedDocs.map((relatedDoc) => (
					<article class="card">
						<h3>{relatedDoc.title}</h3>
						<p>{relatedDoc.excerpt || "Open this explainer for concept revision."}</p>
						<div class="meta-row">
							<span class="pill pill-accent">{relatedDoc.competency}</span>
							<span class="pill">{relatedDoc.type}</span>
						</div>
						<p>
							<a href={routeForDoc(relatedDoc)}>Open related module</a>
						</p>
					</article>
				))}
			</div>
		</section>
	) : null}
</AppLayout>
